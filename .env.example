# Public-safe local development defaults.
# Copy to .env for local overrides. Never commit real secrets or company data.

SPAGHETTI_ENV=development
SPAGHETTI_APP_NAME=Spaghetti Desk
SPAGHETTI_CONFIG_HOST_PATH=./config/config.example.yaml
SPAGHETTI_CONFIG_PATH=/app/config/config.yaml
SPAGHETTI_DEMO_DATA_DIR=/app/examples/demo-data
SPAGHETTI_DATABASE_URL=postgresql+psycopg://spaghetti:spaghetti@postgres:5432/spaghetti
SPAGHETTI_OPERATOR_ID=local-operator
SPAGHETTI_OPERATOR_DISPLAY_NAME=Local Operator
SPAGHETTI_OPERATOR_ROLE=admin

# Optional collector credentials. Keep real values only in the ignored .env.
JENKINS_USERNAME=
JENKINS_TOKEN=

VITE_API_BASE_URL=http://127.0.0.1:8000
